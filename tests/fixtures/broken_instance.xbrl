<?xml version="1.0" encoding="UTF-8"?>
<!-- broken:
     1. TotalAssets references context missing that doesn't exist, XBRL error
     2. TierOneCapital is reported twice in the same context, custom rule XV-001
     3. The duplicate facts carry no decimals attribute, custom rule XV-002 -->
<xbrli:xbrl xmlns:xbrli="http://www.xbrl.org/2003/instance"
            xmlns:link="http://www.xbrl.org/2003/linkbase"
            xmlns:xlink="http://www.w3.org/1999/xlink"
            xmlns:iso4217="http://www.xbrl.org/2003/iso4217"
            xmlns:demo="http://example.com/demo">

  <link:schemaRef xlink:type="simple" xlink:href="demo.xsd"/>

  <xbrli:context id="c1">
    <xbrli:entity>
      <xbrli:identifier scheme="http://standards.iso.org/iso/17442">529900T8BM49AURSDO55</xbrli:identifier>
    </xbrli:entity>
    <xbrli:period>
      <xbrli:instant>2025-12-31</xbrli:instant>
    </xbrli:period>
  </xbrli:context>

  <xbrli:unit id="u-eur">
    <xbrli:measure>iso4217:EUR</xbrli:measure>
  </xbrli:unit>

  <demo:TierOneCapital contextRef="c1" unitRef="u-eur">5000000</demo:TierOneCapital>
  <demo:TierOneCapital contextRef="c1" unitRef="u-eur">4900000</demo:TierOneCapital>
  <demo:TotalAssets contextRef="missing" unitRef="u-eur" decimals="0">125000000</demo:TotalAssets>

</xbrli:xbrl>
